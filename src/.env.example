# === TRADING BOT — CONFIGURATION ===
# Copie ce fichier en ".env" et remplis tes vraies valeurs

# --- Binance --- https://www.binance.com/fr/my/settings/api-management
BINANCE_API_KEY=COLLE_TA_CLE_BINANCE_ICI
BINANCE_API_SECRET=COLLE_TON_SECRET_BINANCE_ICI

# --- Groq AI (gratuit 14400 req/jour) --- https://console.groq.com/keys
GROQ_API_KEY=COLLE_TA_CLE_GROQ_ICI

# --- Anthropic (optionnel, fallback payant) ---
ANTHROPIC_API_KEY=

# --- Telegram --- https://t.me/BotFather -> /newbot
TELEGRAM_BOT_TOKEN=COLLE_TON_TOKEN_ICI
TELEGRAM_CHAT_ID=COLLE_TON_CHAT_ID_ICI

# --- Mode trading ---
# false = LIVE (argent reel) | true = PAPER (simulation)
PAPER_TRADING=false

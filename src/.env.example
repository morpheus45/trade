# ─── Clés API Binance ─────────────────────────────────────────────────────────
# Génère des clés sur : https://www.binance.com/fr/my/settings/api-management
# Permissions requises : Lecture + Trading Spot (PAS de retrait)
API_KEY=REMPLACE_PAR_TA_CLE_BINANCE
API_SECRET=REMPLACE_PAR_TON_SECRET_BINANCE

# ─── Telegram ─────────────────────────────────────────────────────────────────
# Crée un bot via @BotFather sur Telegram
TELEGRAM_BOT_TOKEN=REMPLACE_PAR_TON_TOKEN_TELEGRAM
TELEGRAM_CHAT_ID=REMPLACE_PAR_TON_CHAT_ID

# ─── Anthropic (Claude AI) ────────────────────────────────────────────────────
# Obtenir sur : https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=REMPLACE_PAR_TA_CLE_ANTHROPIC

# ─── Mode de trading ──────────────────────────────────────────────────────────
# true  = PAPER TRADING (simulation) ← RECOMMANDÉ pour commencer
# false = LIVE TRADING  (vrais fonds) ← DANGER
PAPER_TRADING=true
